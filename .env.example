# MyAgent Configuration
# Copy this to .env and modify as needed

# Ollama Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder

# Database
DATABASE_URL=sqlite:///./myagent.db

# Workspace
WORKSPACE_ROOT=./workspace

# Agent Limits
MAX_AGENT_STEPS=30
MAX_RETRIES=3
MAX_TOOL_FAILURES=5
COMMAND_TIMEOUT=120
MODEL_TIMEOUT=60

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Frontend
FRONTEND_PORT=5173

# Logging
LOG_LEVEL=INFO
